{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"],
      "@clients/auth": ["../../packages/auth/src/index.ts"],
      "@clients/request": ["../../packages/request/src/index.ts"],
      "@clients/shared": ["../../packages/shared/src/index.ts"],
      "@clients/types": ["../../packages/types/src/index.ts"]
    }
  }
}
