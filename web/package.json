{
  "name": "@clients/web-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev:auth": "pnpm --filter @clients/app-auth dev",
    "dev:go-note": "pnpm --filter @clients/app-go-note dev",
    "dev:go-chat": "pnpm --filter @clients/app-go-chat dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "lint:ci": "pnpm -r --if-present lint:ci",
    "type-check": "pnpm -r --if-present type-check"
  }
}
